{
  "name": "claude-devtools",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run proxy\" \"npm run client\" \"npm run capture\"",
    "capture": "mitmdump -s server/capture.py -p 9581 --quiet",
    "client": "vite",
    "server": "node --import tsx/esm --watch-path=server server/index.ts",
    "proxy": "node server/proxy.js",
    "build": "vite build && tsc --project tsconfig.server.json",
    "preview": "vite preview"
  },
  "dependencies": {
    "@dagrejs/dagre": "^1.1.2",
    "@xyflow/react": "^12.3.5",
    "cors": "^2.8.6",
    "express": "^4.18.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/cors": "^2.8.17",
    "@types/dagre": "^0.7.52",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.5",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@types/ws": "^8.5.10",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "postcss": "^8",
    "tailwindcss": "^4",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vite": "^5.1.0"
  }
}